{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/butaosuinu/godep-cruiser/main/schema/godep-cruiser.schema.json",
  "title": "godep-cruiser v0.3 configuration",
  "description": "Dependency rules for Go source trees. Regular expressions use Go regexp syntax.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "forbidden": {
      "type": "array",
      "description": "Rules whose matches produce violations. Rule names must be unique across forbidden and required.",
      "items": {
        "$ref": "#/$defs/forbiddenRule"
      }
    },
    "required": {
      "type": "array",
      "description": "Rules requiring every matching source file to import at least one matching dependency. Rule names must be unique across forbidden and required.",
      "items": {
        "$ref": "#/$defs/requiredRule"
      }
    },
    "allowed": {
      "type": "array",
      "description": "Fail-closed allow rules. When present, every dependency must match at least one item. Rule names must be unique within this array.",
      "items": {
        "$ref": "#/$defs/allowedRule"
      }
    },
    "allowedSeverity": {
      "$ref": "#/$defs/severity",
      "description": "Severity of a dependency that matches no allowed rule.",
      "default": "warn"
    }
  },
  "$defs": {
    "severity": {
      "type": "string",
      "enum": [
        "error",
        "warn",
        "info",
        "ignore"
      ]
    },
    "scope": {
      "type": "string",
      "enum": [
        "module",
        "folder"
      ]
    },
    "dependencyType": {
      "type": "string",
      "enum": [
        "stdlib",
        "local",
        "module",
        "unresolved"
      ]
    },
    "ruleName": {
      "type": "string",
      "minLength": 1,
      "description": "User-defined rule name. The synthesized allowed-violation name not-in-allowed is reserved.",
      "not": {
        "const": "not-in-allowed"
      }
    },
    "regexArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "from": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "$ref": "#/$defs/regexArray",
          "description": "Regular expressions matched against the importing file path, or the source package's module-relative path for folder-scoped forbidden rules. Captures supply $1, $2, and later references in to.path and to.pathNot."
        },
        "pathNot": {
          "$ref": "#/$defs/regexArray",
          "description": "Regular expressions that exclude importing file paths, or module-relative source package paths for folder-scoped forbidden rules."
        },
        "orphan": {
          "type": "boolean",
          "description": "Matches files by whether they have no incoming or outgoing dependency."
        },
        "packageName": {
          "$ref": "#/$defs/regexArray",
          "description": "Regular expressions matched against the Go package clause name."
        },
        "numberOfDependentsLessThan": {
          "type": "integer",
          "minimum": 1,
          "description": "Matches files whose package has strictly fewer distinct direct local-package dependents. The loader rejects decimal and exponent notation."
        },
        "numberOfDependentsMoreThan": {
          "type": "integer",
          "minimum": 0,
          "description": "Matches files whose package has strictly more distinct direct local-package dependents. The loader rejects decimal and exponent notation."
        }
      }
    },
    "requiredFrom": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "$ref": "#/$defs/regexArray",
          "description": "Regular expressions matched against the importing file path. Captures supply $1, $2, and later references in to.path and to.pathNot."
        },
        "pathNot": {
          "$ref": "#/$defs/regexArray",
          "description": "Regular expressions that exclude importing file paths."
        },
        "packageName": {
          "$ref": "#/$defs/regexArray",
          "description": "Regular expressions matched against the Go package clause name."
        }
      }
    },
    "to": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "$ref": "#/$defs/regexArray",
          "description": "Regular-expression templates matched against the imported path."
        },
        "pathNot": {
          "$ref": "#/$defs/regexArray",
          "description": "Regular-expression templates that exclude imported paths."
        },
        "dependencyTypes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/dependencyType"
          }
        },
        "dependencyTypesNot": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/dependencyType"
          }
        }
      }
    },
    "forbiddenTo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "$ref": "#/$defs/regexArray",
          "description": "Regular-expression templates matched against the imported path, or the module-relative package path for reachable and folder-scoped forbidden rules."
        },
        "pathNot": {
          "$ref": "#/$defs/regexArray",
          "description": "Regular-expression templates that exclude imported paths, or module-relative package paths for reachable and folder-scoped forbidden rules."
        },
        "reachable": {
          "type": "boolean",
          "description": "Matches packages by transitive reachability in the local dependency graph. True reports reachable targets; false reports unreachable targets."
        },
        "reachableFilePathNot": {
          "$ref": "#/$defs/regexArray",
          "description": "Regular expressions that exclude files forming transitive local-package edges by scan-root-relative path. An edge remains traversable when any file forming it is not excluded. Available only with reachable and does not expand from.path captures."
        },
        "moreUnstable": {
          "type": "boolean",
          "const": true,
          "description": "Matches a local dependency only when its package instability is strictly greater than the source package instability."
        },
        "dependencyTypes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/dependencyType"
          }
        },
        "dependencyTypesNot": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/dependencyType"
          }
        }
      },
      "dependentSchemas": {
        "reachable": {
          "required": [
            "path"
          ],
          "not": {
            "anyOf": [
              {
                "required": [
                  "dependencyTypes"
                ]
              },
              {
                "required": [
                  "dependencyTypesNot"
                ]
              },
              {
                "required": [
                  "moreUnstable"
                ]
              }
            ]
          }
        },
        "moreUnstable": {
          "not": {
            "required": [
              "reachable"
            ]
          },
          "properties": {
            "dependencyTypes": {
              "contains": {
                "const": "local"
              }
            },
            "dependencyTypesNot": {
              "not": {
                "contains": {
                  "const": "local"
                }
              }
            }
          }
        },
        "reachableFilePathNot": {
          "required": [
            "reachable"
          ]
        }
      }
    },
    "forbiddenRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "from",
        "to"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/ruleName"
        },
        "comment": {
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/severity",
          "default": "warn"
        },
        "scope": {
          "$ref": "#/$defs/scope",
          "description": "Evaluation coordinate for this forbidden rule. Module evaluates source-file import edges; folder evaluates local package graph edges.",
          "default": "module"
        },
        "from": {
          "$ref": "#/$defs/from"
        },
        "to": {
          "$ref": "#/$defs/forbiddenTo"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "scope": {
                "const": "folder"
              }
            },
            "required": [
              "scope"
            ]
          },
          "then": {
            "properties": {
              "from": {
                "not": {
                  "anyOf": [
                    {
                      "required": [
                        "orphan"
                      ]
                    },
                    {
                      "required": [
                        "packageName"
                      ]
                    }
                  ]
                }
              },
              "to": {
                "not": {
                  "anyOf": [
                    {
                      "required": [
                        "reachable"
                      ]
                    },
                    {
                      "required": [
                        "reachableFilePathNot"
                      ]
                    },
                    {
                      "required": [
                        "dependencyTypes"
                      ]
                    },
                    {
                      "required": [
                        "dependencyTypesNot"
                      ]
                    }
                  ]
                }
              }
            }
          }
        }
      ]
    },
    "allowedRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "from",
        "to"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/ruleName"
        },
        "comment": {
          "type": "string"
        },
        "from": {
          "$ref": "#/$defs/from"
        },
        "to": {
          "$ref": "#/$defs/to"
        }
      }
    },
    "requiredRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "from",
        "to"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/ruleName"
        },
        "comment": {
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/severity",
          "default": "warn"
        },
        "from": {
          "$ref": "#/$defs/requiredFrom"
        },
        "to": {
          "$ref": "#/$defs/to",
          "minProperties": 1
        }
      }
    }
  }
}
