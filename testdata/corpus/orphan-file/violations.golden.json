{
  "name": "orphan: report a disconnected file",
  "positiveControls": [
    {
      "rule": "no-orphans",
      "from": {
        "path": "cmd/app/main.go",
        "line": 3
      },
      "to": {
        "path": "internal/connected",
        "dependencyType": "local"
      }
    }
  ],
  "violations": [
    {
      "rule": "no-orphans",
      "severity": "error",
      "from": {
        "path": "internal/lonely/lonely.go",
        "line": 1
      }
    }
  ]
}
