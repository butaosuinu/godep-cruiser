{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Monitor",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/scripts/agent-hook.sh",
            "args": ["pre-push"],
            "timeout": 900,
            "statusMessage": "Running pre-push quality gate"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/scripts/agent-hook.sh",
            "args": ["format"],
            "timeout": 600,
            "statusMessage": "Formatting repository"
          }
        ]
      }
    ]
  }
}
