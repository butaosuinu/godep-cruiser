{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "make -C \"${CLAUDE_PROJECT_DIR}\" check 1>&2 || exit 2",
            "timeout": 900,
            "statusMessage": "Running quality gates"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "make -C \"${CLAUDE_PROJECT_DIR}\" fmt 1>&2 || exit 2",
            "timeout": 600,
            "statusMessage": "Formatting repository"
          }
        ]
      }
    ]
  }
}
